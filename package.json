{
  "name": "@ign1s-reiga/marked-presets",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/index.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && cp src/styles/index.css dist/index.css",
    "dev": "tsx tests/dev/server.ts",
    "fmt": "oxfmt",
    "test": "vitest tests/index.test.ts"
  },
  "dependencies": {
    "@shikijs/colorized-brackets": "^4.0.2",
    "@shikijs/transformers": "^4.0.2",
    "@types/hast": "^3.0.4",
    "marked": "^18.0.0",
    "marked-alert": "^2.1.2",
    "marked-footnote": "^1.4.0",
    "marked-shiki": "^1.2.1",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "oxfmt": "^0.44.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "packageManager": "yarn@4.12.0"
}
